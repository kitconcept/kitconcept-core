{
  "field-scope": {
    "type": "array",
    "title": "Scopes",
    "minItems": 1,
    "uniqueItems": true
  },
  "keycloak": {
    "type": "object",
    "properties": {
      "oidc-server_url": {
        "type": "string",
        "title": "Server URL"
      },
      "oidc-realm_name": {
        "type": "string",
        "title": "Realm"
      },
      "oidc-client_id": {
        "type": "string",
        "title": "Client ID"
      },
      "oidc-client_secret": {
        "type": "string",
        "title": "Client Secret"
      },
      "oidc-site-url": {
        "type": "string",
        "title": "Public URL of your site",
        "description": "Please inform the address this site will be available."
      },
      "oidc-scope": {
        "$ref": "#/definitions/field-scope",
        "items": {
          "type": "string",
          "enum": [
            "openid",
            "profile",
            "email"
          ]
        }
      }
    },
    "required": [
      "oidc-server_url",
      "oidc-realm_name",
      "oidc-client_id",
      "oidc-client_secret",
      "oidc-site-url",
      "oidc-scope"
    ]
  },
  "oidc": {
    "type": "object",
    "properties": {
      "oidc-issuer": {
        "type": "string",
        "title": "Issuer (URL)"
      },
      "oidc-client_id": {
        "type": "string",
        "title": "Client ID"
      },
      "oidc-client_secret": {
        "type": "string",
        "title": "Client Secret"
      },
      "oidc-site-url": {
        "type": "string",
        "title": "Public URL of your site",
        "description": "Please inform the address this site will be available."
      },
      "oidc-scope": {
        "$ref": "#/definitions/field-scope",
        "items": {
          "type": "string",
          "enum": [
            "openid",
            "profile",
            "email"
          ]
        }
      }
